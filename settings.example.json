{
  "statusLine": {
    "type": "command",
    "command": "~/.claude/claude-pulse/statusline.sh",
    "padding": 0
  },
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/claude-pulse/notify.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/claude-pulse/notify.sh",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
